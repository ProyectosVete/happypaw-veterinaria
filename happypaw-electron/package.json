{
  "name": "happypaw-veterinaria",
  "version": "1.0.0",
  "description": "Sistema de Gestión Veterinaria HAPPYPAW",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "author": "HAPPYPAW",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.happypaw.veterinaria",
    "productName": "HAPPYPAW Veterinaria",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "icon.ico"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": ["**/*", "!**/venv/**", "!**/__pycache__/**", "!**/.venv/**"]
      },
      {
        "from": "../frontend/build",
        "to": "frontend/build"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "HAPPYPAW"
    }
  }
}